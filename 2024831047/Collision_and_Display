#define SDL_MAIN_HANDLED
#include <SDL2/SDL.h>
#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

/* ─── Window & Grid Settings ─────────────────────────────────────────────── */
#define WINDOW_WIDTH  800
#define WINDOW_HEIGHT 640  /* Taller than the grid so we have room for the score banner */
#define BANNER_HEIGHT 40   /* Height (in pixels) of the top score bar */
#define CELL_SIZE     20   /* Each grid square is 20×20 pixels */
#define GRID_COLS     (WINDOW_WIDTH  / CELL_SIZE)               /* columns*/
#define GRID_ROWS     ((WINDOW_HEIGHT - BANNER_HEIGHT) / CELL_SIZE) /* rows */
#define GAME_SPEED_MS 100  /* The snake moves once every 100 milliseconds */
#define MAX_SNAKE_LEN (GRID_COLS * GRID_ROWS) /* Snake length */

/* ─── Types ───────────────────────────────────────────────────────────────── */

/* The four directions the snake can travel */
typedef enum { UP, DOWN, LEFT, RIGHT } Direction;

/* A single x/y position on the grid */
typedef struct {
    int x, y;
} Segment;

/* The snake itself: an array of segments (head is index 0), its length,
   the direction it is currently moving, and the direction queued for next move */
typedef struct {
    Segment   body[MAX_SNAKE_LEN];
    int       length;
    Direction direction;
    Direction next_direction; 
} Snake;

/* The food pellet */
typedef struct {
    int x, y;
} Food;

/* ─── Global State ────────────────────────────────────────────────────────── */
bool          gameIsRunning = false; /* Main loop keeps running while this is true */
bool          gameOver      = false; /* Changed to true when the snake dies */
SDL_Window   *window        = NULL;
SDL_Renderer *renderer      = NULL;

Snake snake;
Food  food;
int   score = 0;

/* ─── Pixel-Font Data ─────────────────────────────────────────────────────── */

/* Each digit 0-9 is stored as 5 rows of 4 bits (one bit = one pixel column).
   Bit 3 is the leftmost column, bit 0 is the rightmost column. */
const unsigned char font_matrix[10][5] = {
    {0xF,0x9,0x9,0x9,0xF}, // 0
    {0x4,0xC,0x4,0x4,0xE}, // 1
    {0xF,0x1,0xF,0x8,0xF}, // 2
    {0xF,0x1,0xF,0x1,0xF}, // 3
    {0x9,0x9,0xF,0x1,0x1}, // 4
    {0xF,0x8,0xF,0x1,0xF}, // 5
    {0xF,0x8,0xF,0x9,0xF}, // 6
    {0xF,0x1,0x2,0x4,0x4}, // 7
    {0xF,0x9,0xF,0x9,0xF}, // 8
    {0xF,0x9,0xF,0x1,0xF}  // 9
};

/* Pixel-art letters for "GAME OVER" – same 4-bit-wide format as digits */
const unsigned char game_over_logo[8][5] = {
    {0xF,0x8,0xB,0x9,0xF}, // G
    {0xF,0x9,0xF,0x9,0x9}, // A
    {0x9,0xF,0x9,0x9,0x9}, // M
    {0xF,0x8,0xF,0x8,0xF}, // E
    {0xF,0x9,0x9,0x9,0xF}, // O
    {0x9,0x9,0x9,0x9,0xF}, // V
    {0xF,0x8,0xF,0x8,0xF}, // E
    {0xF,0x9,0xF,0xA,0x9}  // R
};

/* ─── Function Prototypes ─────────────────────────────────────────────────── */
void setup(void);
void process_input(void);
void update(void);
void render(void);
void destroy_window(void);
void spawn_food(void);
void draw_circle(int centerX, int centerY, int radius, int r, int g, int b);
void draw_ui_number(const char* text, int x, int y, int scale);
void draw_game_over_word(int x, int y, int scale);

/* ─── Window Initialisation ───────────────────────────────────────────────── */

/* Creates the SDL window and renderer. Returns 1 on success, 0 on failure. */
int initialize_window(void) {
    if (SDL_Init(SDL_INIT_EVERYTHING) != 0) {
        return 0; /* SDL failed to start */
    }
    window = SDL_CreateWindow("Snake Engine - Collision_and_GameOver",
                              SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED,
                              WINDOW_WIDTH, WINDOW_HEIGHT, 0);
    if (!window) return 0;

    /* Accelerated renderer uses the GPU for faster drawing */
    renderer = SDL_CreateRenderer(window, -1, SDL_RENDERER_ACCELERATED);
    return renderer ? 1 : 0;
}

/* ─── Game Setup / Reset ──────────────────────────────────────────────────── */

/* Resets everything so a fresh game (or restart) can begin. */
void setup(void) {
    srand((unsigned int)time(NULL)); /* Seed random so food appears in different spots */

    /* Start with a 3-segment snake pointing right, placed at the centre of the grid */
    snake.length         = 3;
    snake.direction      = RIGHT;
    snake.next_direction = RIGHT;

    int start_col = GRID_COLS / 2;
    int start_row = GRID_ROWS / 2;

    /* Body segments are laid out to the left of the head (index 0 = head) */
    for (int i = 0; i < snake.length; i++) {
        snake.body[i].x = start_col - i;
        snake.body[i].y = start_row;
    }

    score    = 0;
    gameOver = false;
    spawn_food(); /* Place the first food pellet */
}

/* ─── Food Spawning ───────────────────────────────────────────────────────── */

/* Picks a random grid cell for the food, making sure it doesn't land
   on any part of the snake's body. */
void spawn_food(void) {
    bool valid;
    do {
        valid  = true;
        food.x = rand() % GRID_COLS;
        food.y = rand() % GRID_ROWS;

        /* Reject the position if any snake segment already occupies it */
        for (int i = 0; i < snake.length; i++) {
            if (snake.body[i].x == food.x && snake.body[i].y == food.y) {
                valid = false;
                break;
            }
        }
    } while (!valid); /* Keep trying until we find a clear spot */
}

/* ─── Input Handling ──────────────────────────────────────────────────────── */

/* Reads keyboard events and updates the snake's queued direction.
   We only queue the new direction; the actual move happens in update(). */
void process_input(void) {
    SDL_Event event;
    while (SDL_PollEvent(&event)) {
        if (event.type == SDL_QUIT) gameIsRunning = false; /* Window closed */

        if (event.type == SDL_KEYDOWN) {
            switch (event.key.keysym.sym) {
                case SDLK_ESCAPE: gameIsRunning = false; break; /* Quit the game */

                /* Arrow keys and WASD both work – we prevent reversing direction */
                case SDLK_UP:    if (snake.direction != DOWN)  snake.next_direction = UP;    break;
                case SDLK_DOWN:  if (snake.direction != UP)    snake.next_direction = DOWN;  break;
                case SDLK_LEFT:  if (snake.direction != RIGHT) snake.next_direction = LEFT;  break;
                case SDLK_RIGHT: if (snake.direction != LEFT)  snake.next_direction = RIGHT; break;
                case SDLK_w:     if (snake.direction != DOWN)  snake.next_direction = UP;    break;
                case SDLK_s:     if (snake.direction != UP)    snake.next_direction = DOWN;  break;
                case SDLK_a:     if (snake.direction != RIGHT) snake.next_direction = LEFT;  break;
                case SDLK_d:     if (snake.direction != LEFT)  snake.next_direction = RIGHT; break;

                case SDLK_r: if (gameOver) setup(); break; /* R restarts after game over */
            }
        }
    }
}

/* ─── Game Logic Update ───────────────────────────────────────────────────── */

/* Called once per game tick. Moves the snake, checks for collisions,
   and handles eating food. */
void update(void) {
    if (gameOver) return; /* Don't update anything once the game has ended */

    /* Apply the buffered direction (prevents instant 180° reversal) */
    snake.direction = snake.next_direction;

    /* Remember the tail tip before shifting – we'll reuse it if the snake grows */
    Segment tail_tip = snake.body[snake.length - 1];

    /* Shift every segment one step back toward the tail, freeing index 0 for the new head */
    for (int i = snake.length - 1; i > 0; i--) {
        snake.body[i] = snake.body[i - 1];
    }

    /* Move the head one cell in the current direction */
    switch (snake.direction) {
        case UP:    snake.body[0].y--; break;
        case DOWN:  snake.body[0].y++; break;
        case LEFT:  snake.body[0].x--; break;
        case RIGHT: snake.body[0].x++; break;
    }

    /* Check if the head has gone off the edge of the grid */
    if (snake.body[0].x < 0 || snake.body[0].x >= GRID_COLS ||
        snake.body[0].y < 0 || snake.body[0].y >= GRID_ROWS) {
        gameOver = true;
        return;
    }

    /* Check if the head has collided with any other body segment */
    for (int i = 1; i < snake.length; i++) {
        if (snake.body[i].x == snake.body[0].x &&
            snake.body[i].y == snake.body[0].y) {
            gameOver = true;
            return;
        }
    }

    /* Check if the head is on the food pellet */
    if (snake.body[0].x == food.x && snake.body[0].y == food.y) {
        /* Grow the snake by re-adding the tail tip */
        if (snake.length < MAX_SNAKE_LEN) {
            snake.body[snake.length] = tail_tip;
            snake.length++;
        }
        score++;       /* Increase the player's score */
        spawn_food();  /* Place a new food pellet */
    }
}

/* ─── Drawing Helpers ─────────────────────────────────────────────────────── */

/* Draws a filled circle using the midpoint algorithm.
   (centerX, centerY) is the centre in screen pixels; radius is in pixels. */
void draw_circle(int centerX, int centerY, int radius, int r, int g, int b) {
    SDL_SetRenderDrawColor(renderer, r, g, b, 255);
    for (int w = 0; w < radius * 2; w++) {
        for (int h = 0; h < radius * 2; h++) {
            int dx = radius - w; /* Horizontal distance from centre */
            int dy = radius - h; /* Vertical distance from centre */
            /* If the point is inside the circle equation, draw it */
            if ((dx*dx + dy*dy) <= (radius * radius)) {
                SDL_RenderDrawPoint(renderer, centerX + dx, centerY + dy);
            }
        }
    }
}

/* Draws a string of digit characters using the pixel-font defined above.
   'scale' multiplies each pixel so the text can be made larger. */
void draw_ui_number(const char* text, int x, int y, int scale) {
    SDL_SetRenderDrawColor(renderer, 240, 240, 240, 255); /* Off-white colour */
    while (*text) {
        int idx = -1;
        if (*text >= '0' && *text <= '9') idx = *text - '0'; /* Convert char to int index */

        if (idx != -1) {
            /* Walk the 5×4 bitmap for this digit and draw a scaled rectangle per lit pixel */
            for (int row = 0; row < 5; row++) {
                for (int col = 0; col < 4; col++) {
                    if ((font_matrix[idx][row] >> (3 - col)) & 1) {
                        SDL_Rect pixel = { x + col * scale, y + row * scale, scale, scale };
                        SDL_RenderFillRect(renderer, &pixel);
                    }
                }
            }
        }
        x += 5 * scale; /* Advance to the next character position */
        text++;
    }
}

/* Draws the "GAME OVER" pixel-art text using the game_over_logo bitmap. */
void draw_game_over_word(int x, int y, int scale) {
    SDL_SetRenderDrawColor(renderer, 240, 70, 70, 255); /* Crimson / red colour */
    for (int letter = 0; letter < 8; letter++) {
        /* Insert a small gap between "GAME" (letters 0-3) and "OVER" (letters 4-7) */
        if (letter == 4) x += 4 * scale;

        /* Draw each letter the same way as the digit font above */
        for (int row = 0; row < 5; row++) {
            for (int col = 0; col < 4; col++) {
                if ((game_over_logo[letter][row] >> (3 - col)) & 1) {
                    SDL_Rect pixel = { x + col * scale, y + row * scale, scale, scale };
                    SDL_RenderFillRect(renderer, &pixel);
                }
            }
        }
        x += 5 * scale; /* Move right to the next letter */
    }
}

/* ─── Rendering ───────────────────────────────────────────────────────────── */

/* Draws one complete frame: background, banner, score, food, snake,
   and (when needed) the game-over overlay. */
void render(void) {
    /* Clear the screen with a near-black background */
    SDL_SetRenderDrawColor(renderer, 15, 15, 15, 255);
    SDL_RenderClear(renderer);

    /* Draw the dark score banner across the very top */
    SDL_SetRenderDrawColor(renderer, 28, 28, 28, 255);
    SDL_Rect header_rect = { 0, 0, WINDOW_WIDTH, BANNER_HEIGHT };
    SDL_RenderFillRect(renderer, &header_rect);

    /* Draw the current score in the centre of the banner */
    char scoreStr[16];
    snprintf(scoreStr, sizeof(scoreStr), "%d", score);
    draw_ui_number(scoreStr, WINDOW_WIDTH / 2 - 10, 10, 4);

    /* Draw the food pellet as a red circle.
       We offset by BANNER_HEIGHT so it appears in the grid area, not the banner. */
    int foodX = food.x * CELL_SIZE + CELL_SIZE / 2;
    int foodY = food.y * CELL_SIZE + CELL_SIZE / 2 + BANNER_HEIGHT;
    draw_circle(foodX, foodY, CELL_SIZE / 2 - 1, 235, 70, 70);

    /* Draw every snake segment as a circle.
       The head (index 0) is bright green; the body is darker green. */
    for (int i = 0; i < snake.length; i++) {
        int cx = snake.body[i].x * CELL_SIZE + CELL_SIZE / 2;
        int cy = snake.body[i].y * CELL_SIZE + CELL_SIZE / 2 + BANNER_HEIGHT;
        if (i == 0) {
            draw_circle(cx, cy, CELL_SIZE / 2,     90, 245,  90); /* Head – bright green */
        } else {
            draw_circle(cx, cy, CELL_SIZE / 2 - 1, 50, 180,  50); /* Body – dark green */
        }
    }

    /* ── Game-Over Overlay ──────────────────────────────────────────────── */
    if (gameOver) {
        /* Semi-transparent dark panel covering the whole screen */
        SDL_SetRenderDrawBlendMode(renderer, SDL_BLENDMODE_BLEND);
        SDL_SetRenderDrawColor(renderer, 5, 5, 5, 225);
        SDL_Rect overlay = { 0, 0, WINDOW_WIDTH, WINDOW_HEIGHT };
        SDL_RenderFillRect(renderer, &overlay);
        SDL_SetRenderDrawBlendMode(renderer, SDL_BLENDMODE_NONE);

        /* "GAME OVER" pixel-art text, centred horizontally */
        int wordArtWidth = (9 * 5 * 8); /* 9 = spacing factor, 5 cols per letter, 8 letters */
        draw_game_over_word((WINDOW_WIDTH / 2) - (wordArtWidth / 2),
                            (WINDOW_HEIGHT / 2) - 80, 8);

        /* Final score displayed in large digits below the title */
        int digitCount      = strlen(scoreStr);
        int textWidthOffset = (digitCount * 5 * 10) / 2; /* Centre the number */
        draw_ui_number(scoreStr,
                       (WINDOW_WIDTH / 2) - textWidthOffset,
                       (WINDOW_HEIGHT / 2) - 10, 10);
    }

    /* Push everything we've drawn to the screen */
    SDL_RenderPresent(renderer);
}

/* ─── Cleanup ─────────────────────────────────────────────────────────────── */

/* Frees the SDL renderer, window, and shuts down SDL. Always call this before exit. */
void destroy_window(void) {
    SDL_DestroyRenderer(renderer);
    SDL_DestroyWindow(window);
    SDL_Quit();
}

/* ─── Entry Point ─────────────────────────────────────────────────────────── */

int main(int argc, char *argv[]) {
    gameIsRunning = initialize_window(); /* Open the window; stop immediately if it fails */
    setup();                             /* Place the snake and first food pellet */

    Uint32 last_tick = SDL_GetTicks(); /* Track when the last game-logic update happened */

    while (gameIsRunning) {
        process_input(); /* Handle keyboard / window events every frame */

        /* Only advance the game logic when enough time has passed (GAME_SPEED_MS) */
        Uint32 now = SDL_GetTicks();
        if (now - last_tick >= GAME_SPEED_MS) {
            update();
            last_tick = now;
        }

        render();       /* Draw the current frame */
        SDL_Delay(1);   
    }

    destroy_window();
    return 0;
}